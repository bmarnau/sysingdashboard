# =============================================================================
# Sysing Dashboard — Beispiel-Umgebungskonfiguration
# =============================================================================
# Lokal: nach `.env` kopieren und befüllen (NICHT committen).
# Auf Lovable Cloud werden die VITE_SUPABASE_*-Variablen sowie die
# serverseitigen Pendants automatisch injiziert — dort ist KEINE manuelle
# Pflege nötig. Dieser Datei dient der Doku und dem lokalen/Self-Hosted-Setup.

# -----------------------------------------------------------------------------
# Supabase / Lovable Cloud Auth  (PFLICHT für Anmeldung)
# -----------------------------------------------------------------------------
# Clientseitig (werden per Vite-Define in den Browser-Build eingesetzt).
# NIEMALS einen sb_secret_*-Key hier eintragen — nur Publishable/Anon-Key.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Serverseitig (SSR, TanStack-Server-Routes, Backend-Services).
# Optional lokal, wenn ausschließlich der Browser-Client verwendet wird.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Nur für privilegierte Server-Operationen. NIEMALS in VITE_* spiegeln.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Azure-Verbindungen — nur in Production benötigt.
# Im Development-Modus (NODE_ENV != production) werden Mock-Daten verwendet.
# -----------------------------------------------------------------------------
AZURE_SQL_CONNECTION=
AZURE_TABLE_CONNECTION=
AZURE_STORAGE_SAS=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
