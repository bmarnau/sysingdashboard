# Azure-Verbindungen — nur in Production benötigt.
# Im Development-Modus (NODE_ENV != production) werden Mock-Daten verwendet,
# diese Werte dürfen leer bleiben.
#
# Lokal: Datei nach `.env` kopieren und befüllen (NICHT committen).
# Production: Werte über Lovable Cloud Secrets / Wrangler / Hosting-Secrets setzen.

AZURE_SQL_CONNECTION=
AZURE_TABLE_CONNECTION=
AZURE_STORAGE_SAS=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
