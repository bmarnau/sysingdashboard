{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "analyze": "ANALYZE=1 vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "docs:check": "node scripts/check-docs-sync.mjs",
    "security:check": "node scripts/security-check.mjs --json security-report/findings.json --markdown security-report/findings.md",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/__tests__/lib src/__tests__/hooks",
    "test:components": "vitest run src/__tests__/components",
    "test:integration": "vitest run src/__tests__/integration",
    "test:backend": "vitest run src/__tests__/backend",
    "test:api": "vitest run src/__tests__/api",
    "test:io": "vitest run src/__tests__/io",
    "test:backup": "vitest run src/__tests__/backup",
    "test:backup:integrity": "vitest run src/__tests__/backup src/__tests__/io --reporter=default --reporter=json --outputFile.json=test-report/backup-vitest.json && node scripts/backup-integrity/report.mjs",
    "test:azure": "vitest run src/__tests__/azure",
    "test:a11y": "vitest run src/__tests__/a11y",
    "test:security": "vitest run src/__tests__/security --reporter=default --reporter=json --outputFile.json=test-report/security-vitest.json && bun run rbac:check && bun run security:check",
    "test:e2e:security": "playwright test e2e/specs/security",
    "security:report": "node scripts/security/security-report.mjs",
    "security:gate": "node scripts/security/security-report.mjs --gate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "node scripts/generate-e2e-report.mjs",
    "test:perf": "node scripts/check-bundle.mjs",
    "test:docs": "bun run docs:check",
    "test:debt": "node scripts/tech-debt/run.mjs",
    "test:regression": "bun run test && bun run test:e2e",
    "test:full": "bun run lint && bun run test && bun run test:security && bun run test:a11y && bun run test:perf && bun run test:docs && bun run test:debt",
    "test:report": "node scripts/generate-test-report.mjs",
    "test:examples": "node scripts/test-example-files.mjs",
    "rbac:check": "node scripts/check-rbac.mjs",
    "lint:no-console": "node scripts/check-no-console.mjs",
    "api:discover": "node scripts/api-discovery/discover.mjs",
    "api:report": "node scripts/api-discovery/report.mjs",
    "api:gate": "node scripts/api-discovery/report.mjs --gate",
    "test:api:smoke": "vitest run src/__tests__/api/smoke",
    "test:api:functional": "vitest run src/__tests__/api/functional",
    "test:api:discovery": "vitest run src/__tests__/api-discovery",
    "ops:build": "node scripts/ops/build-checks.mjs",
    "ops:bundle": "node scripts/ops/bundle-report.mjs",
    "ops:checks": "node scripts/ops/ops-checks.mjs",
    "ops:e2e": "playwright test e2e/perf e2e/stability e2e/ops",
    "ops:report": "node scripts/ops/report.mjs",
    "test:ops": "bun run ops:build && bun run ops:bundle && bun run ops:checks && bun run ops:e2e && bun run ops:report",
    "report:technical": "node scripts/technical-report/build.mjs",
    "report:technical:ci": "node scripts/technical-report/build.mjs",
    "ci:gate": "node scripts/ci/quality-gate.mjs",
    "test:ci-gate": "vitest run src/__tests__/ci"
  },
